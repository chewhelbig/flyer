<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Therapeutic Autoethnography — Story Prompter</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Georgia', serif;
    background: #faf8f5;
    color: #2c2c2c;
    min-height: 100vh;
  }

  header {
    background: #2c3e50;
    color: #f0ece4;
    padding: 28px 40px 22px;
    border-bottom: 4px solid #c5a96a;
  }
  header h1 {
    font-size: 1.35rem;
    font-weight: normal;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  header p {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #a8b8c8;
    font-style: italic;
  }

  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 36px 24px 60px;
  }

  /* Phase selector */
  .phase-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .phase-btn {
    padding: 8px 16px;
    border: 1.5px solid #c5a96a;
    background: white;
    color: #7a6340;
    border-radius: 20px;
    font-family: Georgia, serif;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.18s;
  }
  .phase-btn:hover { background: #f5ead6; }
  .phase-btn.active { background: #2c3e50; color: #f0ece4; border-color: #2c3e50; }

  /* Context panel */
  .context-panel {
    background: white;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 28px;
  }
  .context-panel label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #888;
    margin-bottom: 7px;
  }
  .context-panel textarea,
  .context-panel input {
    width: 100%;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 10px 13px;
    font-family: Georgia, serif;
    font-size: 0.93rem;
    color: #2c2c2c;
    background: #fafafa;
    resize: vertical;
    outline: none;
    transition: border 0.15s;
  }
  .context-panel textarea:focus,
  .context-panel input:focus { border-color: #c5a96a; }
  .context-row { display: flex; gap: 16px; }
  .context-row > div { flex: 1; }

  /* Prompt card */
  .prompt-card {
    background: white;
    border-left: 4px solid #c5a96a;
    border-radius: 0 10px 10px 0;
    padding: 26px 28px;
    margin-bottom: 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    min-height: 60px;
  }
  .prompt-card.loading {
    display: flex; align-items: center; gap: 12px;
    color: #999; font-style: italic;
  }
  .prompt-label {
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #c5a96a;
    margin-bottom: 11px;
  }
  .prompt-text {
    font-size: 1.06rem;
    line-height: 1.75;
    color: #2c2c2c;
  }
  .prompt-text p { margin-bottom: 12px; }
  .prompt-text p:last-child { margin-bottom: 0; }

  /* Writer area */
  .writer-area {
    background: white;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 20px;
  }
  .writer-area label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #888;
    margin-bottom: 8px;
  }
  .writer-area textarea {
    width: 100%;
    min-height: 160px;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    padding: 14px;
    font-family: Georgia, serif;
    font-size: 0.97rem;
    line-height: 1.8;
    color: #2c2c2c;
    background: #fffdf9;
    resize: vertical;
    outline: none;
    transition: border 0.15s;
  }
  .writer-area textarea:focus { border-color: #c5a96a; }

  /* Actions */
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .btn {
    padding: 10px 22px;
    border-radius: 6px;
    font-family: Georgia, serif;
    font-size: 0.9rem;
    cursor: pointer;
    border: none;
    transition: all 0.18s;
    display: flex; align-items: center; gap: 7px;
  }
  .btn-primary { background: #2c3e50; color: white; }
  .btn-primary:hover { background: #3d5166; }
  .btn-secondary { background: white; color: #2c3e50; border: 1.5px solid #2c3e50; }
  .btn-secondary:hover { background: #f0f4f8; }
  .btn-gold { background: #c5a96a; color: white; }
  .btn-gold:hover { background: #b8975a; }
  .btn:disabled { opacity: 0.45; cursor: not-allowed; }

  /* Feedback */
  .feedback-panel {
    background: #f4f8f2;
    border: 1px solid #b8d4b0;
    border-radius: 10px;
    padding: 22px 26px;
    margin-bottom: 24px;
    display: none;
  }
  .feedback-panel.show { display: block; }
  .feedback-panel h3 {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #5a8a52;
    margin-bottom: 10px;
  }
  .feedback-panel .content { font-size: 0.96rem; line-height: 1.7; }

  /* Principle pill */
  .principle {
    display: inline-block;
    background: #f5ead6;
    color: #7a6340;
    font-size: 0.76rem;
    padding: 3px 10px;
    border-radius: 12px;
    margin: 3px 3px 3px 0;
    border: 1px solid #ddd0b8;
  }

  /* Spinner */
  .spinner {
    width: 18px; height: 18px;
    border: 2px solid #ddd;
    border-top-color: #c5a96a;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .divider {
    border: none;
    border-top: 1px solid #e8e4dc;
    margin: 28px 0;
  }

  .phase-description {
    font-size: 0.87rem;
    color: #777;
    font-style: italic;
    margin-bottom: 22px;
    padding: 12px 16px;
    background: #f0ece4;
    border-radius: 6px;
    line-height: 1.6;
  }
</style>
</head>
<body>

<header>
  <h1>Therapeutic Autoethnography — Story Prompter</h1>
  <p>Based on the methodology of Nicole Chew-Helbig &nbsp;·&nbsp; A tool for the therapist-researcher</p>
</header>

<div class="container">

  <!-- Context -->
  <div class="context-panel">
    <div style="margin-bottom:16px;">
      <label>Your session notes / field data (paste freely — this is your raw material)</label>
      <textarea id="sessionNotes" rows="5" placeholder="Paste your session notes here. These are your field notes — the data from which your story will grow. Include anything: what was said, what you noticed in the room, how you felt in your body, what surprised you, what you wrote afterwards..."></textarea>
    </div>
    <div class="context-row">
      <div>
        <label>Client (pseudonym / composite)</label>
        <input type="text" id="clientName" placeholder="e.g. Matt, Randall, Min..." />
      </div>
      <div>
        <label>Theoretical theme or research question (optional)</label>
        <input type="text" id="researchTheme" placeholder="e.g. confluence, contact boundary, shame..." />
      </div>
    </div>
  </div>

  <!-- Phase selector -->
  <div class="phase-bar">
    <button class="phase-btn active" data-phase="entry" onclick="setPhase('entry', this)">① Entering the Field</button>
    <button class="phase-btn" data-phase="atmosphere" onclick="setPhase('atmosphere', this)">② Atmosphere &amp; Body</button>
    <button class="phase-btn" data-phase="contact" onclick="setPhase('contact', this)">③ The Contact Moment</button>
    <button class="phase-btn" data-phase="epiphany" onclick="setPhase('epiphany', this)">④ Epiphany / Turn</button>
    <button class="phase-btn" data-phase="theory" onclick="setPhase('theory', this)">⑤ Theorising the Story</button>
    <button class="phase-btn" data-phase="feedback" onclick="setPhase('feedback', this)">⑥ Check: Show-Not-Tell</button>
  </div>

  <div id="phaseDescription" class="phase-description"></div>

  <!-- Generated prompt -->
  <div id="promptCard" class="prompt-card">
    <div class="prompt-label">Your writing prompt</div>
    <div class="prompt-text" id="promptText">
      <p>Fill in your session notes above and press <strong>Generate Prompt</strong> to begin.</p>
    </div>
  </div>

  <!-- Actions -->
  <div class="actions">
    <button class="btn btn-primary" id="generateBtn" onclick="generatePrompt()">✦ Generate Prompt</button>
    <button class="btn btn-secondary" onclick="refreshPrompt()">↻ Another Prompt</button>
    <button class="btn btn-gold" id="feedbackBtn" onclick="getFeedback()" disabled>⬡ Reflect on My Writing</button>
  </div>

  <!-- Writer space -->
  <div class="writer-area">
    <label>Your story (write here — present tense, first person, show-not-tell)</label>
    <textarea id="storyText" placeholder="Begin writing here. You are the protagonist. Write in the present tense. Let the scene show itself to the reader — resist the urge to explain what you feel. What do you see, hear, sense?&#10;&#10;'If every person's life is worth a novel, then every therapeutic encounter is worth a story.' — Polster / Chew-Helbig" oninput="checkFeedbackBtn()"></textarea>
  </div>

  <!-- Feedback panel -->
  <div class="feedback-panel" id="feedbackPanel">
    <h3>Reflection on your writing</h3>
    <div class="content" id="feedbackContent"></div>
  </div>

  <hr class="divider">

  <div style="font-size:0.8rem; color:#aaa; line-height:1.7; text-align:center;">
    Principles applied: 
    <span class="principle">Show-not-tell</span>
    <span class="principle">First-person / present tense</span>
    <span class="principle">Phenomenological attitude</span>
    <span class="principle">Therapist as protagonist</span>
    <span class="principle">Heuristic process</span>
    <span class="principle">Story ↔ Theory</span>
  </div>

</div>

<script>
const PHASES = {
  entry: {
    label: "Entering the Field",
    description: "In Therapeutic Autoethnography, the story begins before the first word is spoken. You enter the field as observer, participant, and instrument. How did you arrive at this session? What did you bring with you?",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography, a qualitative research method developed by Nicole Chew-Helbig. Your role is to generate a precise, evocative writing prompt for a psychotherapist who is beginning to write their case story.

The prompt should invite the therapist to ENTER THE SCENE — the physical setting, their embodied state as they arrive, the first impressions of the client, what the room/screen/space felt like. 

RULES for the prompt you generate:
- Address the therapist directly in second person ("You are sitting...")
- Ask them to write in the PRESENT TENSE, first-person
- Encourage show-not-tell: sensory perception, body sensations, spatial details — NOT emotion labels
- Keep the prompt to 3–5 focused sentences
- End with a single, concrete opening question or image-seed
- Do not use jargon or explain the method`
  },
  atmosphere: {
    label: "Atmosphere & Body",
    description: "Atmosphere is data. The aesthetic qualities of the session — the heaviness, the lightness, the silence, the pace — are pre-reflexive, pre-verbal information about the field. Your body registers this before your mind does.",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography. Generate a writing prompt focused on ATMOSPHERE AND SOMATIC EXPERIENCE.

The therapist should be guided to notice and write about: the atmosphere of the session (what Francesetti calls the aesthetic quality of the field), their own body responses, the textures of silence, pace, temperature, the client's physical presence.

RULES:
- Invite purely sensory, somatic description — no interpretation
- The prompt should slow the therapist down, make them linger in what was physically present
- Avoid emotion-labels: not "you felt uneasy" but "notice what your body held"
- 3–4 sentences, ending with a specific sensory question
- Present tense, first person`
  },
  contact: {
    label: "The Contact Moment",
    description: "Contact — in the Gestalt sense — happens at the boundary between self and other. Something passed between you and the client. A moment when the field shifted. Write toward that moment.",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography. Generate a writing prompt that guides the therapist toward THE CONTACT MOMENT — the point in the session where something genuinely met something else.

This could be: a word that landed, a silence that changed everything, a gesture, an unexpected image, a moment of rupture or recognition. The therapist should write what happened at the boundary of self and other.

RULES:
- Encourage the therapist to identify the specific moment — not describe the whole session
- Ask what changed in the field at that instant
- Show-not-tell: what was observable, not what it meant
- 3–5 sentences, closing with: 'Write the moment something shifted — begin with what you heard, saw, or felt in your hands.'
- Do not include interpretation or theory`
  },
  epiphany: {
    label: "Epiphany / The Turn",
    description: "Good autoethnographic stories have an epiphany — a moment of crisis or revelation that provides dramatic tension and resolution. In therapy stories, this is often quiet, internal. What did you suddenly understand? What changed for you?",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography. Generate a writing prompt about THE EPIPHANY OR TURN in the story — the moment of insight, surprise, recognition, or change.

This is about the therapist's own discovery — what they came to understand IN the session or THROUGH the writing. It is the dramatic hinge of the story, the reason the case is worth writing.

RULES:
- Help the therapist identify what they did NOT know at the start that they know now
- Frame this as a quiet, human moment — not dramatic therapy-speak
- Invite them to write the turning point as a scene, not a reflection
- Present tense, first person, show-not-tell
- 3–4 sentences, ending with a sharp, concrete question`
  },
  theory: {
    label: "Theorising the Story",
    description: "In Therapeutic Autoethnography, theory and story exist symbiotically — there is nothing more theoretical than a good story. Now you interweave third-person commentary: the theory that illuminates what happened, or the story that illuminates the theory.",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography. Generate a prompt for the THEORISING phase — helping the therapist interweave theoretical commentary with their story.

In this method, the story is written in first-person/present-tense, and commentary is written in third-person, interleaved as a polyphony. The commentary includes theoretical framing, hindsight, clinical insights.

RULES:
- Invite the therapist to identify ONE concept, term, or theorist that illuminates what happened in the story
- Ask them to write a short third-person commentary paragraph (3–5 sentences) that sits alongside a scene they have already written
- The commentary should not EXPLAIN the story but exist in dialogue with it
- Mention that theory and story are symbiotic — 'Ellis: there is nothing more theoretical than a good story'
- Keep the prompt concrete: ask them to pick a specific moment from their draft`
  },
  feedback: {
    label: "Check: Show-Not-Tell",
    description: "The show-not-tell principle keeps you in a phenomenological attitude — reporting what appeared to you, not what you made of it. This is both a writing principle and an ethical stance: it gives readers space to think and feel for themselves.",
    systemPrompt: `You are a writing coach for Therapeutic Autoethnography. Your task is to give FOCUSED FEEDBACK on a passage of case story writing, specifically checking for the SHOW-NOT-TELL principle.

Check for:
1. Emotion labels ("I felt anxious") — suggest sensory alternatives
2. Interpretive statements ("I could tell he was...") — return to observable
3. Past tense where present tense would be more immediate
4. Moments of telling where showing would bring the reader into the field
5. Also note 1–2 moments where the writing IS evocative and working well

Format your feedback as:
- Brief overall impression (1 sentence)
- Up to 3 specific show-not-tell suggestions (quote the phrase, then suggest alternative)
- 1–2 things that are working
- One closing encouragement

Be warm, precise, and collegial — as a fellow researcher, not an editor.`
  }
};

let currentPhase = 'entry';
let lastPrompt = '';

function setPhase(phase, btn) {
  currentPhase = phase;
  document.querySelectorAll('.phase-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('phaseDescription').textContent = PHASES[phase].description;
  document.getElementById('promptText').innerHTML = '<em style="color:#bbb">Press Generate Prompt to receive your writing prompt for this phase.</em>';
  document.getElementById('promptCard').classList.remove('loading');
  document.getElementById('feedbackPanel').classList.remove('show');
}

// Init description
document.getElementById('phaseDescription').textContent = PHASES['entry'].description;

function checkFeedbackBtn() {
  const hasText = document.getElementById('storyText').value.trim().length > 60;
  document.getElementById('feedbackBtn').disabled = !hasText;
}

async function callClaude(systemPrompt, userMessage) {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: systemPrompt,
      messages: [{ role: "user", content: userMessage }]
    })
  });
  const data = await response.json();
  if (data.content && data.content[0]) return data.content[0].text;
  throw new Error("No response");
}

function formatResponse(text) {
  // Convert markdown-ish to HTML
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/\n/g, '<br>')
    .replace(/^/, '<p>').replace(/$/, '</p>');
}

async function generatePrompt() {
  const notes = document.getElementById('sessionNotes').value.trim();
  const client = document.getElementById('clientName').value.trim();
  const theme = document.getElementById('researchTheme').value.trim();

  const card = document.getElementById('promptCard');
  card.classList.add('loading');
  card.innerHTML = `<div class="spinner"></div><span>Generating your prompt...</span>`;
  document.getElementById('generateBtn').disabled = true;

  const context = [
    notes ? `Session notes: ${notes}` : 'No session notes provided yet.',
    client ? `Client pseudonym: ${client}` : '',
    theme ? `Theoretical theme: ${theme}` : ''
  ].filter(Boolean).join('\n');

  const userMessage = `Phase: ${PHASES[currentPhase].label}\n\n${context}\n\nGenerate a writing prompt for this therapist-researcher.`;

  try {
    const result = await callClaude(PHASES[currentPhase].systemPrompt, userMessage);
    lastPrompt = result;
    card.classList.remove('loading');
    card.innerHTML = `<div class="prompt-label">${PHASES[currentPhase].label} — Writing Prompt</div><div class="prompt-text">${formatResponse(result)}</div>`;
  } catch (e) {
    card.classList.remove('loading');
    card.innerHTML = `<div class="prompt-label">Prompt</div><div class="prompt-text" style="color:#c0392b">Could not reach the API. Please try again.</div>`;
  }
  document.getElementById('generateBtn').disabled = false;
}

async function refreshPrompt() {
  await generatePrompt();
}

async function getFeedback() {
  const story = document.getElementById('storyText').value.trim();
  if (!story) return;

  const panel = document.getElementById('feedbackPanel');
  const content = document.getElementById('feedbackContent');
  panel.classList.add('show');
  content.innerHTML = '<span style="color:#888; font-style:italic"><span class="spinner" style="display:inline-block; width:14px; height:14px; vertical-align:middle; margin-right:8px;"></span>Reflecting on your writing...</span>';

  const notes = document.getElementById('sessionNotes').value.trim();
  const userMessage = `Here is the therapist-researcher's writing:\n\n${story}\n\n${notes ? `Original session notes for context:\n${notes}` : ''}`;

  try {
    const result = await callClaude(PHASES.feedback.systemPrompt, userMessage);
    content.innerHTML = formatResponse(result);
  } catch(e) {
    content.innerHTML = '<span style="color:#c0392b">Could not reach the API. Please try again.</span>';
  }
}
</script>
</body>
</html>
