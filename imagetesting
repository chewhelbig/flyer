// Deduplicate
const unique = [...new Map(IMAGES.map(i => [i.path, i])).values()];
const BASE = "https://nikhelbig.at/";

let tested = 0, ok = 0, miss = 0;
const grid = document.getElementById('grid');

document.getElementById('nTotal').textContent = unique.length;
document.getElementById('nTest').textContent = unique.length;

function updateStats() {
  document.getElementById('nOk').textContent = ok;
  document.getElementById('nMiss').textContent = miss;
  document.getElementById('nTest').textContent = unique.length - tested;
  document.getElementById('progressBar').style.width = ((tested / unique.length) * 100) + '%';
  if (tested === unique.length) {
    document.getElementById('progressBar').style.background = '#4ade80';
  }
}

// Filter buttons
document.querySelectorAll('.filters button').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filters button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.f;
    document.querySelectorAll('.card').forEach(c => {
      if (f === 'all') c.classList.remove('hidden');
      else if (f === 'ok') c.classList.toggle('hidden', !c.classList.contains('ok'));
      else if (f === 'miss') c.classList.toggle('hidden', !c.classList.contains('miss'));
    });
  });
});

unique.forEach((img, i) => {
  const card = document.createElement('div');
  card.className = 'card testing';
  card.dataset.path = img.path;

  const url = BASE + img.path;
  const shortPath = img.path.split('/').slice(-2).join('/');

  card.innerHTML = `
    <div class="card-img broken" id="imgwrap-${i}">Testing…</div>
    <div class="card-body">
      <div class="card-title">${img.article}</div>
      <div class="card-path">${img.path}</div>
      <span class="card-type ${img.type}">${img.type}</span>
      <div class="card-status testing" id="status-${i}">Testing…</div>
      <div class="card-action" id="action-${i}"></div>
    </div>
  `;
  grid.appendChild(card);

  // Test image
  const testImg = new Image();
  testImg.onload = () => {
    card.classList.remove('testing');
    card.classList.add('ok');
    const wrap = document.getElementById('imgwrap-' + i);
    wrap.outerHTML = `<img class="card-img" src="${url}" loading="lazy">`;
    document.getElementById('status-' + i).className = 'card-status ok';
    document.getElementById('status-' + i).textContent = '✓ Found — ' + testImg.naturalWidth + '×' + testImg.naturalHeight;
    ok++; tested++; updateStats();
  };
  testImg.onerror = () => {
    card.classList.remove('testing');
    card.classList.add('miss');
    document.getElementById('status-' + i).className = 'card-status miss';
    document.getElementById('status-' + i).textContent = '✗ MISSING — 404';
    document.getElementById('action-' + i).textContent = 'Upload this file from SiteGround to static/' + img.path;
    miss++; tested++; updateStats();
  };
  // Stagger requests to avoid hammering
  setTimeout(() => { testImg.src = url; }, i * 80);
});
</script>
