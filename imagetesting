<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #111; color: #e0e0e0; padding: 1.5rem; }
h1 { font-size: 1.6rem; margin-bottom: 0.3rem; }
.sub { color: #888; font-size: 0.85rem; margin-bottom: 1.5rem; }
.stats { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.stat { background: #1a1a1a; border: 1px solid #333; border-radius: 8px; padding: 0.8rem 1.2rem; min-width: 120px; }
.stat .n { font-size: 1.8rem; font-weight: 700; }
.stat .l { font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.2rem; }
.stat.ok .n { color: #4ade80; }
.stat.miss .n { color: #f87171; }
.stat.test .n { color: #fbbf24; }
.stat.total .n { color: #60a5fa; }

.filters { margin-bottom: 1rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
.filters button { background: #1a1a1a; border: 1px solid #333; color: #ccc; padding: 0.4rem 0.9rem; border-radius: 5px; font-size: 0.8rem; cursor: pointer; }
.filters button.active { border-color: #60a5fa; color: #60a5fa; background: rgba(96,165,250,0.1); }

.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.8rem; }
.card { background: #1a1a1a; border: 1px solid #333; border-radius: 6px; overflow: hidden; }
.card.ok { border-left: 3px solid #4ade80; }
.card.miss { border-left: 3px solid #f87171; }
.card.testing { border-left: 3px solid #fbbf24; }
.card-img { width: 100%; height: 140px; object-fit: cover; background: #222; display: block; }
.card-img.broken { display: flex; align-items: center; justify-content: center; color: #f87171; font-size: 0.75rem; height: 80px; }
.card-body { padding: 0.6rem; }
.card-title { font-size: 0.8rem; font-weight: 600; margin-bottom: 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-path { font-size: 0.65rem; color: #888; word-break: break-all; line-height: 1.3; }
.card-type { font-size: 0.6rem; padding: 0.15rem 0.4rem; border-radius: 10px; display: inline-block; margin-top: 0.3rem; }
.card-type.preview { background: rgba(96,165,250,0.15); color: #60a5fa; }
.card-type.inline { background: rgba(167,139,250,0.15); color: #a78bfa; }
.card-status { font-size: 0.65rem; font-weight: 600; margin-top: 0.3rem; }
.card-status.ok { color: #4ade80; }
.card-status.miss { color: #f87171; }
.card-status.testing { color: #fbbf24; }
.card-action { font-size: 0.65rem; color: #f97316; margin-top: 0.2rem; }
.hidden { display: none !important; }
.progress { background: #222; border-radius: 4px; height: 6px; margin-bottom: 1.5rem; overflow: hidden; }
.progress-bar { height: 100%; background: #fbbf24; transition: width 0.3s; border-radius: 4px; }
